{%- doc -%}
  Loads Almarai Arabic font for RTL locales.
  This snippet is conditionally rendered when the locale is Arabic (ar).

  @example
  {% render 'font-arabic' %}
{%- enddoc -%}

<style>
  @font-face {
    font-family: 'Almarai';
    src: url('{{ 'almarai-300.woff2' | asset_url }}') format('woff2');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Almarai';
    src: url('{{ 'almarai-400.woff2' | asset_url }}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Almarai';
    src: url('{{ 'almarai-700.woff2' | asset_url }}') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Almarai';
    src: url('{{ 'almarai-800.woff2' | asset_url }}') format('woff2');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }
</style>
